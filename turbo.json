{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.json"],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "out/**",
        "public/build/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
